@{
    ViewData["Title"] = "System Configurations";
}

<div class="mb-4">
    <span class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Control Panel</span>
    <h2 class="font-bold text-white mb-1" style="font-size: 1.8rem; letter-spacing: -0.5px;">System Configurations</h2>
    <p class="text-muted" style="font-size: 0.9rem;">Manage company metadata, localization preferences, and security access rates.</p>
</div>

<form method="post" asp-action="Save">
    @Html.AntiForgeryToken()

    <!-- Enterprise Metadata Section -->
    <div class="executive-card shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-2">
            <i class="bi bi-building text-warning fs-5"></i>
            <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Company Details</h4>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Corporate Entity Name</label>
                <input type="text" name="companyName" value="Tibr Enterprise Ltd" class="form-control executive-input" required />
            </div>

            <div class="col-12">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Support & Billing Email</label>
                <input type="email" name="companyEmail" value="billing@tibr.com" class="form-control executive-input" required />
            </div>
        </div>
    </div>

    <!-- Localization & Processing -->
    <div class="executive-card shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-2">
            <i class="bi bi-globe text-warning fs-5"></i>
            <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Localization & Currency</h4>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Default Base Currency</label>
                <select name="currency" class="form-select executive-input">
                    <option value="USD" selected>USD ($) - United States Dollar</option>
                    <option value="SAR">SAR (SR) - Saudi Riyal</option>
                    <option value="EGP">EGP (E£) - Egyptian Pound</option>
                    <option value="JOD">JOD (JD) - Jordanian Dinar</option>
                </select>
            </div>
            
            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Session Token Timeout</label>
                <input type="text" name="tokenTimeout" value="60 minutes" class="form-control executive-input" />
            </div>
        </div>
    </div>

    <!-- Switch Settings -->
    <div class="executive-card shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-2">
            <i class="bi bi-shield-exclamation text-warning fs-5"></i>
            <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Security & Operations</h4>
        </div>

        <div class="executive-card p-3 d-flex justify-content-between align-items-center shadow-none mb-0" style="background-color: #f8fafc;">
            <div style="max-width: 75%;">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="bi bi-hammer text-warning"></i>
                    <h6 class="mb-0 text-dark" style="font-weight: 700;">Maintenance Mode</h6>
                </div>
                <p class="text-muted mb-0" style="font-size: 0.8rem; line-height: 1.3;">Redirect API customers to a standard temporary static page during upgrades.</p>
            </div>
            <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" role="switch" name="maintenanceMode" id="toggle-maintenance">
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-gold py-3 px-5 fw-bold shadow-sm w-100 mb-4">
        SAVE CONFIGURATION
    </button>
</form>
