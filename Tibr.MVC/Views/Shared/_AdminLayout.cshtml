<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tibr | Admin Panel</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    <!-- Admin CSS -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <!-- Admin Products CSS -->
    <link rel="stylesheet" href="~/css/admin-products.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ════════════════════════════════════════════════
     SIDEBAR
════════════════════════════════════════════════ -->
    <aside class="tibr-sidebar" id="sidebar">

        <!-- Logo -->
        <div class="sidebar-brand">
            <div class="brand-icon">
                <i class="fa-solid fa-coins"></i>
            </div>
            <div class="brand-text">
                <span class="brand-name">Tibr</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </div>

        <!-- System Status -->
        <div class="sidebar-status">
            <span class="status-dot"></span>
            <span class="status-text">System Online</span>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">

            <div class="nav-group">
                <span class="nav-group-label">Overview</span>
                <a asp-controller="Dashboard" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i>
                    <span>Dashboard</span>
                </a>
                <a asp-controller="Dashboard" asp-action="Reports"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")">
                    <i class="fa-solid fa-chart-bar"></i>
                    <span>Reports & Analytics</span>
                </a>
            </div>

            <div class="nav-group">
                <span class="nav-group-label">Store Management</span>
                <a asp-controller="Product" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                    <i class="fa-solid fa-layer-group"></i>
                    <span>Products</span>
                    <span class="nav-badge" id="badgeProducts">—</span>
                </a>
                <a asp-controller="Category" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                    <i class="fa-solid fa-tags"></i>
                    <span>Categories</span>
                </a>
                <a asp-controller="Order" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Orders</span>
                    <span class="nav-badge nav-badge-warning" id="badgeOrders">—</span>
                </a>
            </div>

            <div class="nav-group">
                <span class="nav-group-label">Customers & Support</span>
                <a asp-controller="Customer" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")">
                    <i class="fa-solid fa-users"></i>
                    <span>Customers</span>
                </a>
                <a asp-controller="Support" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Support" ? "active" : "")">
                    <i class="fa-solid fa-headset"></i>
                    <span>Support Tickets</span>
                    <span class="nav-badge nav-badge-danger" id="badgeSupport">—</span>
                </a>
                <a asp-controller="Review" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Review" ? "active" : "")">
                    <i class="fa-solid fa-star-half-stroke"></i>
                    <span>Reviews</span>
                    <span class="nav-badge-soon">Soon</span>
                </a>
            </div>

        </nav>

        <!-- Bottom -->
        <div class="sidebar-footer">
            <a href="#" class="nav-item">
                <i class="fa-solid fa-gear"></i>
                <span>Settings</span>
            </a>
            <a asp-controller="Auth" asp-action="Logout" class="nav-item nav-item-danger">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- ════════════════════════════════════════════════
     MAIN CONTENT
════════════════════════════════════════════════ -->
    <div class="tibr-main" id="mainContent">

        <!-- TOP NAVBAR -->
        <header class="tibr-topbar" id="topbar">
            <div class="topbar-left">

                <!-- Sidebar toggle (mobile) -->
                <button class="topbar-toggle" id="sidebarToggle">
                    <i class="fa-solid fa-bars"></i>
                </button>

                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="topbar-breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#">Tibr</a></li>
                        <li class="breadcrumb-item active">@(ViewData["PageTitle"] ?? ViewData["Title"])</li>
                    </ol>
                </nav>
            </div>

            <div class="topbar-right">

                <!-- Search -->
                <div class="topbar-search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Quick search..." class="search-input" />
                </div>

                <!-- Live gold price ticker -->
                <div class="topbar-ticker">
                    <i class="fa-solid fa-coins ticker-icon"></i>
                    <span class="ticker-label">GOLD</span>
                    <span class="ticker-price" id="goldPrice">$2,342</span>
                    <span class="ticker-change up">+1.2%</span>
                </div>

                <!-- Notifications -->
                <button class="topbar-btn" id="notifBtn">
                    <i class="fa-solid fa-bell"></i>
                    <span class="topbar-badge" id="notifCount">3</span>
                </button>

                <!-- Admin Avatar -->
                <div class="topbar-admin">
                    <div class="admin-avatar">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <div class="admin-info">
                        <span class="admin-name">Admin</span>
                        <span class="admin-role">Super Admin</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="tibr-content" id="pageContent">

            <!-- Flash messages -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-tibr alert-tibr-success">
                    <i class="fa-solid fa-circle-check"></i>
                    @TempData["Success"]
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-tibr alert-tibr-danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @TempData["Error"]
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <!-- Sidebar Overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Admin JS -->
    <script src="~/js/admin.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
