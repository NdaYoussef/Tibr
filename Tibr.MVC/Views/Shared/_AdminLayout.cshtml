<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tibr | Admin Panel</title>
    <script>
            (function () {
                var saved = localStorage.getItem('tibr-admin-theme') || 'light';
                document.documentElement.setAttribute('data-theme', saved);
            })();
    </script>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    <!-- 1. Theme variables FIRST (defines --gold, --bg-card etc. for both themes) -->
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />
    <!-- 2. Admin design system (uses the var tokens) -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <!-- 3. Feature-specific sheets -->
    <link rel="stylesheet" href="~/css/admin-products.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-support.css" asp-append-version="true" />

    <!-- Notification panel styles -->
    <style>
        .notif-panel {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        width: 340px;
        max-height: 420px;
        background: var(--bg-card, #fff);
        border: 1px solid rgba(0,0,0,0.08);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        z-index: 1050;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        }

        .notif-panel.d-none {
        display: none;
        }

        .notif-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        font-weight: 600;
        font-size: 0.9rem;
        }

        .notif-panel-header a {
        font-size: 0.8rem;
        font-weight: 400;
        text-decoration: none;
        color: var(--gold, #c99a2e);
        cursor: pointer;
        }

        .notif-panel-body {
        overflow-y: auto;
        max-height: 360px;
        }

        .notif-item {
        display: block;
        padding: 10px 16px;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        text-decoration: none;
        color: inherit;
        }

        .notif-item:hover {
        background: rgba(0,0,0,0.03);
        }

        .notif-item.unread {
        background: rgba(201, 154, 46, 0.06);
        }

        .notif-item-title {
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 2px;
        }

        .notif-item-message {
        font-size: 0.8rem;
        color: #777;
        }

        .notif-item-time {
        font-size: 0.72rem;
        color: #aaa;
        margin-top: 4px;
        }

        .notif-empty {
        padding: 24px 16px;
        text-align: center;
        color: #999;
        font-size: 0.85rem;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ════════════════════════════════════════════════
     SIDEBAR
════════════════════════════════════════════════ -->
    <aside class="tibr-sidebar" id="sidebar">

        <div class="sidebar-brand">
            <div class="brand-icon"><i class="fa-solid fa-coins"></i></div>
            <div class="brand-text">
                <span class="brand-name">Tibr</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </div>

        <div class="sidebar-status">
            <span class="status-dot"></span>
            <span class="status-text">System Online</span>
        </div>

        <nav class="sidebar-nav">

            <div class="nav-group">
                <span class="nav-group-label">Overview</span>
                <a asp-controller="Dashboard" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i>
                    <span>Dashboard</span>
                </a>
                <a asp-controller="Dashboard" asp-action="Reports"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")">
                    <i class="fa-solid fa-chart-bar"></i>
                    <span>Reports & Analytics</span>
                </a>
            </div>

            <div class="nav-group">
                <span class="nav-group-label">Store Management</span>
                <a asp-controller="Product" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                    <i class="fa-solid fa-layer-group"></i>
                    <span>Products</span>
                    <span class="nav-badge" id="badgeProducts">—</span>
                </a>
                <a asp-controller="Category" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                    <i class="fa-solid fa-tags"></i>
                    <span>Categories</span>
                </a>
                <a asp-controller="Orders" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Orders</span>
                    <span class="nav-badge nav-badge-warning" id="badgeOrders">—</span>
                </a>
            </div>

            <div class="nav-group">
                <span class="nav-group-label">Customers & Support</span>
                <a asp-controller="Users" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="fa-solid fa-users"></i>
                    <span>Users</span>
                </a>
                <a asp-controller="Admin" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                    <i class="fa-solid fa-user-shield"></i>
                    <span>Admins</span>
                </a>
                <a asp-controller="Support" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Support" ? "active" : "")">
                    <i class="fa-solid fa-headset"></i>
                    <span>Support Tickets</span>
                    <span class="nav-badge nav-badge-danger" id="badgeSupport">—</span>
                </a>
                <a asp-controller="Review" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Review" ? "active" : "")">
                    <i class="fa-solid fa-star-half-stroke"></i>
                    <span>Reviews</span>
                   
                </a>
            </div>

        </nav>

        <div class="sidebar-footer">
            <!-- Theme toggle in sidebar footer -->
            <button class="theme-toggle-btn w-100" data-theme-toggle title="Switch theme">
                <div class="theme-toggle-track">
                    <div class="theme-toggle-thumb"></div>
                </div>
                <span class="theme-label-light">Light Mode</span>
                <span class="theme-label-dark">Dark Mode</span>
            </button>

            <a asp-controller="Settings" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
                <i class="fa-solid fa-gear"></i>
                <span>Settings</span>
            </a>

            <a asp-controller="AdminAuth" asp-action="Logout" class="nav-item nav-item-danger">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- ════════════════════════════════════════════════
     MAIN CONTENT
════════════════════════════════════════════════ -->
    <div class="tibr-main" id="mainContent">

        <header class="tibr-topbar" id="topbar">
            <div class="topbar-right">
                <button class="topbar-toggle" id="sidebarToggle">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <nav aria-label="breadcrumb" class="topbar-breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item d-flex justify-content-center align-items-center mt-1"><a href="#">Tibr</a></li>
                        <li class="breadcrumb-item active d-flex justify-content-center align-items-center mt-1">@(ViewData["PageTitle"] ?? ViewData["Title"])</li>
                    </ol>
                </nav>
            </div>

            <div class="topbar-left">
                <div class="topbar-search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Quick search..." class="search-input" />
                </div>

                <div class="topbar-ticker">
                    <i class="fa-solid fa-coins ticker-icon"></i>
                    <span class="ticker-label">GOLD</span>
                    <span class="ticker-price" id="goldPrice">$2,342</span>
                    <span class="ticker-change up">+1.2%</span>
                </div>

                <!-- Theme toggle in topbar (compact icon version) -->
                <button class="topbar-btn" data-theme-toggle title="Toggle light/dark mode">
                    <i class="fa-solid fa-circle-half-stroke theme-icon-topbar"></i>
                </button>

                <div class="topbar-notif-wrapper" style="position: relative;">
                    <button class="topbar-btn" id="notifBtn">
                        <i class="fa-solid fa-bell"></i>
                        <span class="topbar-badge d-none" id="notifCount">0</span>
                    </button>

                    <div id="notifPanel" class="notif-panel d-none">
                        <div class="notif-panel-header">
                            <span>Notifications</span>
                            <a href="#" id="markAllReadBtn">Mark all read</a>
                        </div>
                        <div class="notif-panel-body" id="notifPanelBody">
                            <div class="notif-empty" id="notifEmpty">No notifications</div>
                        </div>
                    </div>
                </div>

                <div class="topbar-admin">
                    <div class="admin-avatar">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <div class="admin-info">
                        <span class="admin-name">Admin</span>
                        <span class="admin-role">Super Admin</span>
                    </div>
                </div>
            </div>
        </header>

        <main class="tibr-content" id="pageContent">

            @if (TempData["Success"] != null)
            {
                <div class="alert-tibr alert-tibr-success">
                    <i class="fa-solid fa-circle-check"></i>
                    @TempData["Success"]
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-tibr alert-tibr-danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @TempData["Error"]
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>

    <script>
        (function () {
        const notifBtn = document.getElementById('notifBtn');
        const notifPanel = document.getElementById('notifPanel');
        const notifCount = document.getElementById('notifCount');
        const notifPanelBody = document.getElementById('notifPanelBody');
        const notifEmpty = document.getElementById('notifEmpty');
        const markAllReadBtn = document.getElementById('markAllReadBtn');

        let unreadCount = 0;

        function updateBadge() {
        if (unreadCount > 0) {
        notifCount.textContent = unreadCount > 9 ? '9+' : unreadCount;
        notifCount.classList.remove('d-none');
        } else {
        notifCount.classList.add('d-none');
        }
        }

        function timeAgo(dateStr) {
        const diff = Math.floor((new Date() - new Date(dateStr)) / 60000);
        if (diff < 1) return 'just now';
        if (diff < 60) return `${diff}m ago`;
        if (diff < 1440) return `${Math.floor(diff / 60)}h ago`;
        return `${Math.floor(diff / 1440)}d ago`;
        }

        function renderNotification(n, prepend) {
        notifEmpty?.remove();

        const item = document.createElement('a');
        item.href = n.actionUrl || '#';
        item.className = 'notif-item' + (n.isRead ? '' : ' unread');
        item.dataset.id = n.id;
        item.innerHTML = `
        <div class="notif-item-title">${n.title}</div>
        <div class="notif-item-message">${n.message}</div>
        <div class="notif-item-time">${timeAgo(n.createdAt)}</div>
        `;

        if (prepend) {
        notifPanelBody.prepend(item);
        } else {
        notifPanelBody.appendChild(item);
        }
        }

        async function loadNotifications() {
        try {
        const res = await fetch('/Notifications/GetRecent');
        if (!res.ok) return;
        const data = await res.json();
        data.forEach(n => renderNotification(n, false));
        unreadCount = data.filter(n => !n.isRead).length;
        updateBadge();
        } catch (err) {
        console.error('Failed to load notifications:', err);
        }
        }

        // Toggle panel open/closed
        notifBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        notifPanel.classList.toggle('d-none');
        });

        // Close panel when clicking outside
        document.addEventListener('click', function (e) {
        if (!notifPanel.contains(e.target) && e.target !== notifBtn) {
        notifPanel.classList.add('d-none');
        }
        });

        markAllReadBtn.addEventListener('click', async function (e) {
        e.preventDefault();
        await fetch('/Notifications/MarkAllAsRead', { method: 'POST' });
        document.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
        unreadCount = 0;
        updateBadge();
        });

        // SignalR live connection
        const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/notifications')
        .withAutomaticReconnect()
        .build();

        connection.on('ReceiveNotification', function (n) {
        renderNotification(n, true);
        unreadCount++;
        updateBadge();
        });

        connection.start().catch(err => console.error('SignalR connection error:', err));

        loadNotifications();
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>