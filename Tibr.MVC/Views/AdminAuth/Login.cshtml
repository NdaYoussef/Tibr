@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tibr | Admin Panel</title>
    <script>
            (function () {
                var saved = localStorage.getItem('tibr-admin-theme') || 'light';
                document.documentElement.setAttribute('data-theme', saved);
            })();
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
            body {
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                background-color: var(--bg);
                margin: 0;
                padding: 20px;
            }

            .login-container {
                width: 100%;
                max-width: 440px;
            }

            .login-logo {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 12px;
                margin-bottom: 30px;
            }

                .login-logo i {
                    font-size: 2.2rem;
                    color: var(--gold);
                }

                .login-logo h1 {
                    font-size: 2.2rem;
                    font-weight: 700;
                    margin: 0;
                    color: var(--text-primary);
                }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="d-flex justify-content-end mb-4">
            <button class="theme-toggle-btn" data-theme-toggle title="Toggle light/dark mode">
                <div class="theme-toggle-track">
                    <div class="theme-toggle-thumb"></div>
                </div>
                <span class="theme-label-light">Light Mode</span>
                <span class="theme-label-dark">Dark Mode</span>
            </button>
        </div>

        <div class="executive-card shadow-sm p-4 p-sm-5 accent-top">
            <div class="login-logo">
                <i class="fa-solid fa-coins"></i>
                <h1>Tibr</h1>
            </div>
            <h3 class="text-center mb-1 text-white" style="font-weight: 700;">Admin Control Panel</h3>
            <p class="text-center text-muted mb-4" style="font-size: 0.9rem;">Sign in to access your administrative workspace</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-tibr alert-tibr-danger mb-4">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <div class="flex-grow-1">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        }
                    </div>
                </div>
            }

            <form method="post" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="Email" class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Email Address</label>
                    <input type="email" class="form-control executive-input w-100" id="Email" name="Email"
                           asp-for="Email" placeholder="Enter your email" required>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label for="Password" class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Password</label>
                    <input type="password" class="form-control executive-input w-100" id="Password" name="Password"
                           asp-for="Password" placeholder="Enter your password" required>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
                        <input type="checkbox" class="form-check-input" id="RememberMe" name="RememberMe" asp-for="RememberMe">
                        <label class="form-check-label text-muted fw-semibold" for="RememberMe" style="font-size: 0.8rem; cursor: pointer;">Remember me</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-gold w-100 py-3 mb-3" style="font-weight: 700;">SIGN IN</button>
            </form>

            <div class="text-center mt-3">
                <a href="/" class="text-muted text-decoration-none" style="font-size: 0.85rem; font-weight: 500;">
                    <i class="fa-solid fa-arrow-left me-1"></i> Return to Home
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <script>
        // Bootstrap validation script
        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var forms = document.getElementsByClassName('needs-validation');
                var validation = Array.prototype.filter.call(forms, function (form) {
                    form.addEventListener('submit', function (event) {
                        if (form.checkValidity() === false) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            }, false);
        })();
    </script>
</body>
</html>