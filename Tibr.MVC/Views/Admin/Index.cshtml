@model AdminListViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Directory";
    var totalPages = Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}
<div class="mb-3">
    <span class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Administration</span>
    <h2 class="font-bold text-white mb-1" style="font-size: 1.8rem; letter-spacing: -0.5px;">Admin Directory</h2>
    <p class="text-muted" style="font-size: 0.9rem;">Manage system administrators and security credentials.</p>
</div>

<div class="mb-3">
    <form method="get" asp-action="Index">
        <input type="hidden" name="sortBy" value="@Model.SortBy" />
        <input type="hidden" name="sortDescending" value="@Model.SortDescending.ToString().ToLower()" />
        <div class="search-container mb-3 shadow-sm">
            <i class="bi bi-search"></i>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control executive-input w-100" placeholder="Search administrators..." />
        </div>
    </form>
    
    <details class="executive-card p-3 mb-4 shadow-sm" style="border-radius: 14px;">
        <summary class="accordion-summary text-muted fw-semibold" style="font-size: 0.85rem;">
            <span><i class="bi bi-sliders me-2"></i> Toggle Sort & Filter Options</span>
            <i class="bi bi-chevron-down text-muted" style="font-size: 0.75rem;"></i>
        </summary>
        <div class="mt-3 pt-3 border-top border-light">
            <form method="get" asp-action="Index" class="row g-2">
                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                <div class="col-6">
                    <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.65rem;">Sort By</label>
                    <select name="sortBy" class="form-select executive-input" onchange="this.form.submit()">
                        <option value="Name" selected="@(Model.SortBy == "Name" ? "selected" : null)">Name</option>
                        <option value="Email" selected="@(Model.SortBy == "Email" ? "selected" : null)">Email</option>
                        <option value="Status" selected="@(Model.SortBy == "Status" ? "selected" : null)">Status</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.65rem;">Direction</label>
                    <select name="sortDescending" class="form-select executive-input" onchange="this.form.submit()">
                        <option value="false" selected="@(!Model.SortDescending ? "selected" : null)">Ascending</option>
                        <option value="true" selected="@(Model.SortDescending ? "selected" : null)">Descending</option>
                    </select>
                </div>
            </form>
        </div>
    </details>
</div>

<div class="mb-4">
    @if (Model.Admins.Count == 0)
    {
        <div class="executive-card text-center p-5 text-muted">
            <i class="bi bi-shield-lock display-4 mb-3 text-secondary"></i>
            <div>No matching administrators found.</div>
        </div>
    }
    else
    {
        @foreach (var admin in Model.Admins)
        {
            var statusClass = "badge-inactive";
            var statusLabel = "INACTIVE";
            if (admin.Status == "Active")
            {
                statusClass = "badge-verified";
                statusLabel = "ACTIVE";
            }

            <div class="executive-card accent-top shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="position-relative">
                            <div class="rounded-circle border border-warning d-flex align-items-center justify-content-center bg-dark text-warning" style="width: 52px; height: 52px; border-width: 2px !important;">
                                <i class="fa-solid fa-user-shield" style="font-size: 1.25rem;"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="mb-0 text-white" style="font-size: 1.15rem; font-weight: 700;">@admin.Name</h4>
                            <span class="text-muted" style="font-size: 0.8rem;">@admin.Email</span>
                        </div>
                    </div>
                    <div>
                        <span class="pill-badge @statusClass">@statusLabel</span>
                    </div>
                </div>
                
                <div class="row g-2 mt-2">
                    <div class="col-6">
                        <a asp-action="Details" asp-route-id="@admin.Id" class="btn btn-outline-gold w-100 py-2" style="font-size: 0.8rem; font-weight: 700;">Details</a>
                    </div>
                    <div class="col-6">
                        <a asp-action="Edit" asp-route-id="@admin.Id" class="btn btn-gold w-100 py-2" style="font-size: 0.8rem; font-weight: 700;">Edit</a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<a asp-action="Create" class="fab-btn" title="Add New Admin">
    <i class="bi bi-plus-lg"></i>
</a>

@if (totalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination pagination-custom justify-content-center">
            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" 
                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDescending="@Model.SortDescending.ToString().ToLower()">Previous</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-sortDescending="@Model.SortDescending.ToString().ToLower()">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" 
                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDescending="@Model.SortDescending.ToString().ToLower()">Next</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Auto-hide alerts after 5 seconds
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                setTimeout(function () {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 5000);
            });
        });
    </script>
}