
@model DeleteAdminViewModel

@{
    ViewData["Title"] = $"Delete Admin - {Model.Name}";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow border-left-danger">
                <div class="card-header py-3 bg-danger">
                    <h6 class="m-0 font-weight-bold text-white">
                        <i class="fas fa-exclamation-triangle"></i> Delete Admin
                    </h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger" role="alert">
                        <strong><i class="fas fa-exclamation-circle"></i> Warning!</strong>
                        <p>You are about to permanently delete this admin account. This action cannot be undone.</p>
                    </div>

                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <h6 class="text-muted">Full Name</h6>
                                    <p class="h5">@Model.Name</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-muted">Email Address</h6>
                                    <p class="h5">@Model.Email</p>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <h6 class="text-muted">Admin ID</h6>
                                    <p class="h5">@Model.Id</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-muted">Status</h6>
                                    <p>
                                        <span class="badge bg-@(Model.Status == "Active" ? "success" : "danger")">
                                            @Model.Status
                                        </span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning" role="alert">
                        <strong><i class="fas fa-info-circle"></i> Important:</strong>
                        <ul class="mb-0 mt-2">
                            <li>All associated records will remain in the system</li>
                            <li>The admin account will be permanently removed</li>
                            <li>This action is irreversible</li>
                        </ul>
                    </div>

                    <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" class="mt-4">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Yes, Delete This Admin
                            </button>
                            <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <a href="@Url.Action("Details", "Admin", new { id = Model.Id })" class="btn btn-info">
                                <i class="fas fa-eye"></i> View Details
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Confirm before deletion
            const deleteForm = document.querySelector('form');
            if (deleteForm) {
                deleteForm.addEventListener('submit', function (e) {
                    if (!confirm('Are you absolutely sure you want to delete this admin? This action cannot be undone.')) {
                        e.preventDefault();
                    }
                });
            }
        });
    </script>

}

