
@model DeleteAdminViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = $"Delete Admin - {Model.Name}";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-gold px-3 py-2" style="font-weight: 600;">
        <i class="bi bi-arrow-left me-1"></i> Back to Admins Directory
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <!-- Delete Confirmation Card -->
        <div class="executive-card shadow-sm p-4 mb-4" style="border: 1px solid #dc3545;">
            <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-2" style="border-bottom-color: #dc3545 !important;">
                <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                <h4 class="mb-0 text-white" style="font-size: 1.2rem; font-weight: 700;">Permanently Remove Administrator</h4>
            </div>

            <div class="alert-tibr alert-tibr-danger mb-4">
                <i class="bi bi-exclamation-octagon-fill me-2 fs-5 text-danger"></i>
                <div class="text-white">
                    <strong>Warning:</strong> You are about to permanently delete this administrator account. This action is irreversible.
                </div>
            </div>

            <!-- Admin Summary Details -->
            <div class="executive-card p-3 mb-4 shadow-none text-dark" style="background-color: var(--bg-card2, #1a1a1a);">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted text-uppercase fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Full Name</label>
                        <div class="text-dark fw-bold" style="font-size: 1.05rem;">@Model.Name</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted text-uppercase fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Email Address</label>
                        <div class="text-dark fw-bold" style="font-size: 1.05rem;">@Model.Email</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted text-uppercase fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Administrator ID</label>
                        <div class="text-dark fw-medium">#@Model.Id</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted text-uppercase fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Account Status</label>
                        <div>
                            <span class="pill-badge @(Model.Status == "Active" ? "badge-verified" : "badge-inactive")">
                                @(Model.Status == "Active" ? "ACTIVE" : "INACTIVE")
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Confirmation Form -->
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" id="deleteForm">
                <div class="row g-2">
                    <div class="col-md-6">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-gold w-100 py-3" style="font-weight: 700;">CANCEL</a>
                    </div>
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-danger w-100 py-3" style="font-weight: 700;">
                            <i class="bi bi-trash me-1"></i> YES, DELETE ADMIN
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const deleteForm = document.getElementById('deleteForm');
            if (deleteForm) {
                deleteForm.addEventListener('submit', function (e) {
                    if (!confirm('Are you absolutely sure you want to delete this administrator? This action cannot be undone.')) {
                        e.preventDefault();
                    }
                });
            }
        });
    </script>

}

