
@model EditAdminViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = $"Edit Admin - {Model.Email}";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-gold px-3 py-2" style="font-weight: 600;">
        <i class="bi bi-arrow-left me-1"></i> Back to Admins Directory
    </a>
</div>

<form method="post" asp-action="Edit" class="needs-validation" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />

    <!-- Profile Header Card -->
    <div class="executive-card text-center py-4 mb-4 shadow-sm">
        <div class="position-relative d-inline-block mb-3">
            <div class="rounded-circle border border-warning d-flex align-items-center justify-content-center bg-dark text-warning mx-auto" style="width: 80px; height: 80px; border-width: 2px !important;">
                <i class="fa-solid fa-user-shield" style="font-size: 2rem;"></i>
            </div>
        </div>
        <h5 class="mb-1 text-white" style="font-size: 1.1rem; font-weight: 700;">@Model.Name</h5>
        <p class="text-muted mb-0" style="font-size: 0.8rem;">Admin ID: #@Model.Id</p>
    </div>

    <!-- Admin Details Card -->
    <div class="executive-card accent-top shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-2">
            <i class="bi bi-person-badge text-warning fs-5"></i>
            <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Admin Information</h4>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Name" class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Full Name</label>
                <input asp-for="Name" class="form-control executive-input" placeholder="Enter full name" required />
                <span asp-validation-for="Name" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-12">
                <label asp-for="Email" class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Email Address</label>
                <input asp-for="Email" class="form-control executive-input" placeholder="Enter email address" required />
                <span asp-validation-for="Email" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
                <small class="form-text text-muted" style="font-size: 0.8rem;"><i class="bi bi-info-circle"></i> Changing the email address will update the admin's login credentials.</small>
            </div>

            <div class="col-12">
                <label asp-for="Status" class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Status</label>
                <select asp-for="Status" class="form-select executive-input" required>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
                <span asp-validation-for="Status" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>
        </div>
    </div>

    <!-- Submit buttons -->
    <div class="row g-2 mb-4">
        <div class="col-6">
            <a asp-action="Index" class="btn btn-outline-gold w-100 py-3" style="font-weight: 700;">CANCEL</a>
        </div>
        <div class="col-6">
            <button type="submit" class="btn btn-gold w-100 py-3" style="font-weight: 700;"><i class="bi bi-save me-1"></i> SAVE CHANGES</button>
        </div>
    </div>
</form>

<!-- Danger Zone Card -->
<div class="executive-card shadow-sm p-4 mb-4" style="border: 1px solid #dc3545;">
    <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-2" style="border-bottom-color: #dc3545 !important;">
        <i class="bi bi-exclamation-triangle text-danger fs-5"></i>
        <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Danger Zone</h4>
    </div>
    <p class="text-muted" style="font-size: 0.85rem;">Permanently remove this administrator account from the system. This action cannot be undone.</p>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger w-100 py-3" style="font-weight: 700;">
        <i class="bi bi-trash me-1"></i> DELETE ADMIN ACCOUNT
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

