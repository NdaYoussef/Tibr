@model EditAdminViewModel
@{
    ViewData["Title"] = $"Edit Admin - {Model.Email}";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0 text-gray-800">Edit Admin</h1>
            <p class="text-muted">Editing: <strong>@Model.Email</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Admin Details</h6>
                </div>
                <div class="card-body">
                    <form method="post" novalidate class="needs-validation">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger" role="alert">
                                <h4 class="alert-heading">Validation Error!</h4>
                                <ul>
                                    @foreach (var modelState in ViewData.ModelState.Values)
                                    {
                                        @foreach (var error in modelState.Errors)
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Full Name</label>
                            <input type="text" asp-for="Name" class="form-control" placeholder="Enter full name" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input type="email" asp-for="Email" class="form-control" placeholder="Enter email address" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                            <small class="form-text text-muted">Changing the email address may affect the admin's login credentials.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select" required>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="alert alert-warning" role="alert">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Note:</strong> Changing the status to "Inactive" will prevent the admin from logging in.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Help</h6>
                </div>
                <div class="card-body">
                    <p><strong>Full Name:</strong> Update the admin's full name if needed (2-100 characters).</p>
                    <p><strong>Email:</strong> You can change the email address, but ensure it's unique.</p>
                    <p><strong>Status:</strong> Set whether the admin account is Active or Inactive.</p>
                    <div class="alert alert-info" role="alert">
                        <small><i class="fas fa-info-circle"></i> Inactive admins cannot log in to the system.</small>
                    </div>
                </div>
            </div>

            <div class="card shadow mt-3">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-danger">Danger Zone</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">Delete this admin account permanently:</p>
                    <a href="@Url.Action("Delete", "Admin", new { id = Model.Id })" class="btn btn-danger btn-sm w-100">
                        <i class="fas fa-trash"></i> Delete Admin
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
