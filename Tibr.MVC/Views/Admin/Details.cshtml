
@model AdminViewModel

@{
    ViewData["Title"] = $"Admin Details - {Model.Name}";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0 text-gray-800">Admin Details</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-user-shield"></i> @Model.Name
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Full Name</h6>
                            <p>@Model.Name</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Email Address</h6>
                            <p>
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Status</h6>
                            <p>
                                <span class="badge bg-@(Model.Status == "Active" ? "success" : "danger")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Admin ID</h6>
                            <p>@Model.Id</p>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Created Date</h6>
                            <p>@Model.CreatedAt.ToString("g")</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Last Modified</h6>
                            <p>@(Model.UpdatedAt?.ToString("g") ?? "Never")</p>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <a href="@Url.Action("Edit", "Admin", new { id = Model.Id })" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Edit Admin
                        </a>
                        <a href="@Url.Action("Delete", "Admin", new { id = Model.Id })" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Admin Information</h6>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        <div class="list-group-item">
                            <small class="text-muted d-block">Status</small>
                            <span class="badge bg-@(Model.Status == "Active" ? "success" : "warning")">
                                @Model.Status
                            </span>
                        </div>
                        <div class="list-group-item">
                            <small class="text-muted d-block">Account Age</small>
                            <span>@((DateTime.UtcNow - Model.CreatedAt).Days) days</span>
                        </div>
                        <div class="list-group-item">
                            <small class="text-muted d-block">Last Modified</small>
                            <span>@(Model.UpdatedAt.HasValue ? $"{(DateTime.UtcNow - Model.UpdatedAt.Value).Days} days ago" : "Never")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow mt-3">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Edit", "Admin", new { id = Model.Id })" class="btn btn-warning btn-sm w-100 mb-2">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary btn-sm w-100">
                        <i class="fas fa-list"></i> View All Admins
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

