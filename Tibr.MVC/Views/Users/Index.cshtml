@model Tibr.MVC.Models.Users.UserListViewModel
@{
    ViewData["Title"] = "User Directory";
}

<div class="mb-3">
    <span class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Administration</span>
    <h2 class="font-bold text-white mb-1" style="font-size: 1.8rem; letter-spacing: -0.5px;">User Directory</h2>
    <p class="text-muted" style="font-size: 0.9rem;">Manage executive access levels and member profiles.</p>
</div>

<!-- Search Panel -->
<div class="mb-3">
    <form method="get" asp-action="Index">
        <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
        <input type="hidden" name="kycStatusFilter" value="@Model.KycStatusFilter" />
        <div class="search-container mb-3 shadow-sm">
            <i class="bi bi-search"></i>
            <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control executive-input w-100" placeholder="Search elite members..." />
        </div>
    </form>
    
    <!-- Filter Toggle -->
    <details class="executive-card p-3 mb-4 shadow-sm" style="border-radius: 14px;">
        <summary class="accordion-summary text-muted fw-semibold" style="font-size: 0.85rem;">
            <span><i class="bi bi-sliders me-2"></i> Toggle Filter Options</span>
            <i class="bi bi-chevron-down text-muted" style="font-size: 0.75rem;"></i>
        </summary>
        <div class="mt-3 pt-3 border-top border-light">
            <form method="get" asp-action="Index" class="row g-2">
                <input type="hidden" name="searchQuery" value="@Model.SearchQuery" />
                <div class="col-6">
                    <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.65rem;">Account Status</label>
                    <select name="statusFilter" class="form-select executive-input" onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        <option value="Active" selected="@(Model.StatusFilter == "Active" ? "selected" : null)">Active</option>
                        <option value="Suspended" selected="@(Model.StatusFilter == "Suspended" ? "selected" : null)">Suspended</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.65rem;">KYC Verification</label>
                    <select name="kycStatusFilter" class="form-select executive-input" onchange="this.form.submit()">
                        <option value="">All Verifications</option>
                        <option value="Approved" selected="@(Model.KycStatusFilter == "Approved" ? "selected" : null)">Approved</option>
                        <option value="Pending" selected="@(Model.KycStatusFilter == "Pending" ? "selected" : null)">Pending</option>
                        <option value="Rejected" selected="@(Model.KycStatusFilter == "Rejected" ? "selected" : null)">Rejected</option>
                    </select>
                </div>
            </form>
        </div>
    </details>
</div>

<!-- User Card List -->
<div class="mb-4">
    @if (!Model.Users.Any())
    {
        <div class="executive-card text-center p-5 text-muted">
            <i class="bi bi-people display-4 mb-3 text-secondary"></i>
            <div>No matching elite members found.</div>
        </div>
    }
    else
    {
        @foreach (var user in Model.Users)
        {
            // Status helper badge matching mockup: VERIFIED / PENDING / INACTIVE
            var statusClass = "badge-pending";
            var statusLabel = "PENDING";
            if (user.KycStatus == "Approved" && user.Status == "Active")
            {
                statusClass = "badge-verified";
                statusLabel = "VERIFIED";
            }
            else if (user.Status == "Suspended" || user.KycStatus == "Rejected")
            {
                statusClass = "badge-inactive";
                statusLabel = "INACTIVE";
            }
            
            // Circular portrait matching mockup image links
            var avatarUrl = "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=150&auto=format&fit=crop"; // Male profile
            if (user.FirstName.Equals("Sarah", StringComparison.OrdinalIgnoreCase) || user.FirstName.Equals("Fatima", StringComparison.OrdinalIgnoreCase) || user.FirstName.Equals("Aria", StringComparison.OrdinalIgnoreCase) || user.FirstName.Equals("Elena", StringComparison.OrdinalIgnoreCase))
            {
                avatarUrl = "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop"; // Female profile
            }

            <div class="executive-card accent-top shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="position-relative">
                            <img src="@avatarUrl" class="rounded-circle border border-warning" alt="Avatar" style="width: 52px; height: 52px; object-fit: cover; border-width: 2px !important;" />
                        </div>
                        <div>
                            <h4 class="mb-0 text-white" style="font-size: 1.15rem; font-weight: 700;">@user.FullName</h4>
                            <span class="text-muted" style="font-size: 0.8rem;">@user.Email</span>
                        </div>
                    </div>
                    <div>
                        <span class="pill-badge @statusClass">@statusLabel</span>
                    </div>
                </div>
                
                <div class="row g-2 mt-2">
                    <div class="col-6">
                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-gold w-100 py-2" style="font-size: 0.8rem; font-weight: 700; border-color: #cbd5e1; color: var(--text-dark);">Details</a>
                    </div>
                    <div class="col-6">
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-gold w-100 py-2" style="font-size: 0.8rem; font-weight: 700;">Edit</a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Floating Action Button for Adding New User -->
<a asp-action="Create" class="fab-btn" title="Add New User">
    <i class="bi bi-plus-lg"></i>
</a>

<!-- Pagination Panel -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination pagination-custom justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" 
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-searchQuery="@Model.SearchQuery"
                   asp-route-statusFilter="@Model.StatusFilter"
                   asp-route-kycStatusFilter="@Model.KycStatusFilter">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-searchQuery="@Model.SearchQuery"
                       asp-route-statusFilter="@Model.StatusFilter"
                       asp-route-kycStatusFilter="@Model.KycStatusFilter">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" 
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-searchQuery="@Model.SearchQuery"
                   asp-route-statusFilter="@Model.StatusFilter"
                   asp-route-kycStatusFilter="@Model.KycStatusFilter">Next</a>
            </li>
        </ul>
    </nav>
}
