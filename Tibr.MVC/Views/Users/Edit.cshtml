@model Tibr.MVC.Models.Users.UserEditViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = $"Edit Profile - {Model.FirstName}";
}

<form method="post" asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />

    <!-- Portrait Headshot Card -->
    <div class="executive-card text-center py-4 mb-4 shadow-sm">
        <div class="position-relative d-inline-block mb-3">
            @{
                // Choose avatar based on gender/name
                var avatarUrl = "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=150&auto=format&fit=crop";
                if (Model.FirstName.Equals("Sarah", StringComparison.OrdinalIgnoreCase) || Model.FirstName.Equals("Fatima", StringComparison.OrdinalIgnoreCase) || Model.FirstName.Equals("Aria", StringComparison.OrdinalIgnoreCase) || Model.FirstName.Equals("Elena", StringComparison.OrdinalIgnoreCase))
                {
                    avatarUrl = "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop";
                }
            }
            <img src="@avatarUrl"
                 class="rounded-circle border border-light shadow-sm"
                 alt="Portrait Placeholder"
                 style="width: 100px; height: 100px; object-fit: cover; background-color: #f1f5f9;" />
            <button type="button" class="btn btn-warning rounded-circle position-absolute bottom-0 end-0 p-0 d-flex align-items-center justify-content-center shadow-sm"
                    style="width: 32px; height: 32px; border: 2px solid #ffffff; background-color: var(--accent-gold); color: #ffffff;">
                <i class="bi bi-pencil-fill" style="font-size: 0.8rem;"></i>
            </button>
        </div>
        <h5 class="mb-1 text-white" style="font-size: 1rem; font-weight: 700;">@Model.FirstName @Model.LastName</h5>
        <p class="text-muted mb-0" style="font-size: 0.8rem;">User ID: #@Model.Id</p>
    </div>

    <!-- Personal Information Card -->
    <div class="executive-card shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-2">
            <i class="bi bi-person-badge text-warning fs-5"></i>
            <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Personal Information</h4>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">First Name</label>
                <input asp-for="FirstName" class="form-control executive-input" />
                <span asp-validation-for="FirstName" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Last Name</label>
                <input asp-for="LastName" class="form-control executive-input" />
                <span asp-validation-for="LastName" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-12">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Email Address</label>
                <input asp-for="Email" class="form-control executive-input" />
                <span asp-validation-for="Email" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-12">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Phone Number</label>
                <input asp-for="Phone" class="form-control executive-input" />
                <span asp-validation-for="Phone" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Account status</label>
                <select asp-for="Status" class="form-select executive-input">
                    <option value="Active">Active</option>
                    <option value="Suspended">Suspended</option>
                </select>
                <span asp-validation-for="Status" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">KYC Verification status</label>
                <select asp-for="KycStatus" class="form-select executive-input">
                    <option value="Pending">Pending</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                </select>
                <span asp-validation-for="KycStatus" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="col-12">
                <label class="form-label text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Organizational Role</label>
                <select asp-for="Role" class="form-select executive-input">
                    <option value="Administrator">Administrator</option>
                    <option value="Manager">Manager</option>
                    <option value="Executive Member">Executive Member</option>
                    <option value="Standard User">Standard User</option>
                </select>
                <span asp-validation-for="Role" class="text-danger mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>
        </div>
    </div>

    <!-- Access & Permissions Card -->
    <div class="executive-card shadow-sm p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-2">
            <i class="bi bi-shield-lock text-warning fs-5"></i>
            <h4 class="mb-0 text-white" style="font-size: 1.1rem; font-weight: 700;">Access & Permissions</h4>
        </div>

        <!-- Permission toggle 1 -->
        <div class="executive-card p-3 d-flex justify-content-between align-items-center shadow-none mb-3" style="background-color: #f8fafc;">
            <div style="max-width: 75%;">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="bi bi-bar-chart-line text-warning"></i>
                    <h6 class="mb-0 text-dark" style="font-weight: 700;">Analytics Access</h6>
                </div>
                <p class="text-muted mb-0" style="font-size: 0.8rem; line-height: 1.3;">Grant viewing rights to executive dashboard and financial reporting.</p>
            </div>
            <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" role="switch" asp-for="AnalyticsAccess" id="toggle-analytics">
            </div>
        </div>

        <!-- Permission toggle 2 -->
        <div class="executive-card p-3 d-flex justify-content-between align-items-center shadow-none mb-0" style="background-color: #f8fafc;">
            <div style="max-width: 75%;">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="bi bi-card-list text-warning"></i>
                    <h6 class="mb-0 text-dark" style="font-weight: 700;">System Logs</h6>
                </div>
                <p class="text-muted mb-0" style="font-size: 0.8rem; line-height: 1.3;">Allow user to audit activity logs and system modification history.</p>
            </div>
            <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" role="switch" asp-for="SystemLogs" id="toggle-logs">
            </div>
        </div>
    </div>

    <!-- Submit buttons -->
    <div class="row g-2 mb-4">
        <div class="col-6">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-gold w-100 py-3" style="font-weight: 700; border-color: #cbd5e1; color: var(--text-dark);">CANCEL</a>
        </div>
        <div class="col-6">
            <button type="submit" class="btn btn-gold w-100 py-3" style="font-weight: 700;"><i class="bi bi-save me-1"></i> SAVE CHANGES</button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}