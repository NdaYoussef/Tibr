@model Tibr.MVC.Models.ReportsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Reports & Analytics";
    ViewData["PageTitle"] = "Reports";

    var monthLabels = System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Select(m => m.Month));
    var monthRevenue = System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Select(m => m.Revenue));
    var monthOrders = System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Select(m => m.Orders));
}

<!-- ══════════════════════════════════════════════
     PAGE HEADER
══════════════════════════════════════════════ -->
<div class="page-header">
    <div>
        <h1 class="page-title">Reports & Analytics</h1>
        <p class="page-sub">Comprehensive business and financial performance analysis</p>
    </div>
    <div class="page-header-actions">
        <button class="btn-tibr btn-tibr-outline" onclick="exportPDF()">
            <i class="fa-solid fa-file-pdf"></i>
            Export PDF
        </button>
        <button class="btn-tibr btn-tibr-gold" onclick="exportExcel()">
            <i class="fa-solid fa-file-excel"></i>
            Export Excel
        </button>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     REPORT TYPE TABS
══════════════════════════════════════════════ -->
<div class="report-tabs">
    <a asp-action="Reports"
           asp-route-reportType="revenue"
           asp-route-from="@Model.FromDate?.ToString("yyyy-MM")"
           asp-route-to="@Model.ToDate?.ToString("yyyy-MM")"
           data-report-type="revenue"
           class="report-tab @(Model.ReportType == "revenue" ? "active" : "")">
        <i class="fa-solid fa-coins"></i> Revenue Report
    </a>
    <a asp-action="Reports"
           asp-route-reportType="products"
           data-report-type="products"
           class="report-tab @(Model.ReportType == "products" ? "active" : "")">
        <i class="fa-solid fa-layer-group"></i> Product Performance
    </a>
    <a asp-action="Reports"
           asp-route-reportType="customers"
           data-report-type="customers"
           class="report-tab @(Model.ReportType == "customers" ? "active" : "")">
        <i class="fa-solid fa-users"></i> Customer Report
    </a>
    <a asp-action="Reports"
           asp-route-reportType="inventory"
           data-report-type="inventory"
           class="report-tab @(Model.ReportType == "inventory" ? "active" : "")">
        <i class="fa-solid fa-boxes-stacked"></i> Inventory
    </a>
</div>

<!-- ══════════════════════════════════════════════
     DATE FILTER BAR
══════════════════════════════════════════════ -->
<form asp-action="Reports" method="get" class="report-filter-bar">
    <input type="hidden" name="reportType" value="@Model.ReportType" />
    <div class="filter-group">
        <label>From Month</label>
        <input type="month" name="from" value="@Model.FromDate?.ToString("yyyy-MM")" class="filter-input" />
    </div>
    <div class="filter-group">
        <label>To Month</label>
        <input type="month" name="to" value="@Model.ToDate?.ToString("yyyy-MM")" class="filter-input" />
    </div>
    <button type="submit" class="btn-tibr btn-tibr-gold mt-4">
        <i class="fa-solid fa-filter"></i>
        Apply Filter
    </button>
    <a asp-action="Reports" asp-route-reportType="@Model.ReportType" class="btn-tibr btn-tibr-outline mt-4">
        <i class="fa-solid fa-rotate-left"></i>
        Reset
    </a>
</form>


<!-- ══════════════════════════════════════════════
     HEADER CHART
══════════════════════════════════════════════ -->
<div class="chart-card reveal mb-4">
    <div class="chart-card-header">
        <div>
            <h3 class="chart-title">Monthly Revenue & Orders</h3>
            <p class="chart-sub">Last 12 months</p>
        </div>
    </div>
    <div class="chart-body">
        <canvas id="reportChart" height="240"></canvas>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     DATA TABLE
══════════════════════════════════════════════ -->
<div class="table-card reveal" id="reportTable">
    <div class="table-card-header">
        <h3 class="chart-title">
            @(Model.ReportType switch
            {
                "revenue" => "Revenue Details",
                "products" => "Product Performance",
                "customers" => "Customer Data",
                "inventory" => "Inventory Report",
                _ => "Data"
            })
        </h3>
        <div class="table-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="tableSearch" placeholder="Search table..." class="filter-input" />
        </div>
    </div>
    <div class="table-responsive">

        @* ── Sales / Revenue ── *@

        @* ── Revenue ── Paid orders only, grouped by product, with margin *@
        @if (Model.ReportType == "revenue" && Model.RevenueRows.Any())
        {
            <table class="tibr-table" id="dataTable">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Metal</th>
                        <th>Units Sold</th>
                        <th>Total Revenue</th>
                        <th>Total Cost</th>
                        <th>Net Margin</th>
                        <th>Margin %</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.RevenueRows)
                    {
                        <tr class="table-row-anim">
                            <td><strong>@row.ProductName</strong></td>
                            <td>
                                <span class="metal-badge @(row.MetalType == "Gold" ? "metal-gold" : "metal-silver")">
                                    @row.MetalType
                                </span>
                            </td>
                            <td>@row.UnitsSold units</td>
                            <td><strong class="price-cell">@row.TotalRevenue.ToString("N0") EGP</strong></td>
                            <td>@row.TotalCost.ToString("N0") EGP</td>
                            <td>
                                <strong class="@(row.NetMargin >= 0 ? "price-cell" : "text-danger")">
                                    @row.NetMargin.ToString("N0") EGP
                                </strong>
                            </td>
                            <td>
                                <span class="@(row.MarginPercent >= 20 ? "text-success fw-bold" : row.MarginPercent >= 10 ? "text-warning fw-bold" : "text-danger fw-bold")">
                                    @row.MarginPercent %
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @* ── Product Performance ── *@
        @if (Model.ReportType == "products" && Model.ProductRows.Any())
        {
            <table class="tibr-table" id="dataTable">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Metal Type</th>
                        <th>Units Sold</th>
                        <th>Revenue</th>
                        <th>Stock</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ProductRows)
                    {
                        <tr class="table-row-anim">
                            <td><strong>@row.ProductName</strong></td>
                            <td>
                                <span class="metal-badge @(row.MetalType == "Gold" ? "metal-gold" : "metal-silver")">
                                    @row.MetalType
                                </span>
                            </td>
                            <td>@row.TotalSold units</td>
                            <td><strong class="price-cell">@row.Revenue.ToString("N0") EGP</strong></td>
                            <td>
                                <span class="@(row.Stock == 0 ? "text-danger fw-bold" : row.Stock <= 5 ? "text-warning fw-bold" : "text-success")">
                                    @row.Stock
                                </span>
                            </td>
                            <td>
                                <span class="status-badge @(row.Status == "Active" ? "badge-success" : "badge-secondary")">
                                    <span class="status-dot"></span>
                                    @row.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @* ── Inventory ── *@
        @if (Model.ReportType == "inventory" && Model.InventoryRows.Any())
        {
            <table class="tibr-table" id="dataTable">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Metal Type</th>
                        <th>Stock</th>
                        <th>Stock Status</th>
                        <th>Buy Price</th>
                        <th>Sell Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.InventoryRows)
                    {
                        <tr class="table-row-anim">
                            <td><strong>@row.ProductName</strong></td>
                            <td>@row.Category</td>
                            <td>
                                <span class="metal-badge @(row.MetalType == "Gold" ? "metal-gold" : "metal-silver")">
                                    @row.MetalType
                                </span>
                            </td>
                            <td>
                                <span class="@(row.StockStatus == "Out" ? "text-danger fw-bold" : row.StockStatus == "Low" ? "text-warning fw-bold" : "text-success")">
                                    @row.Stock
                                </span>
                            </td>
                            <td>
                                <span class="status-badge @(row.StockStatus == "Out" ? "badge-danger" : row.StockStatus == "Low" ? "badge-warning" : "badge-success")">
                                    <span class="status-dot"></span>
                                    @row.StockStatus
                                </span>
                            </td>
                            <td>@row.BuyPrice.ToString("N0") EGP</td>
                            <td><strong class="price-cell">@row.SellPrice.ToString("N0") EGP</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @* ── Customers ── *@
        @if (Model.ReportType == "customers" && Model.CustomerRows.Any())
        {
            <table class="tibr-table" id="dataTable">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Orders</th>
                        <th>Total Spent</th>
                        <th>Joined</th>
                        <th>KYC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.CustomerRows)
                    {
                        <tr class="table-row-anim">
                            <td>
                                <div class="customer-cell">
                                    <div class="customer-avatar">@row.CustomerName.FirstOrDefault()</div>
                                    <span>@row.CustomerName</span>
                                </div>
                            </td>
                            <td>@row.Email</td>
                            <td>@row.TotalOrders</td>
                            <td><strong class="price-cell">@row.TotalSpent.ToString("N0") EGP</strong></td>
                            <td><span class="date-cell">@row.JoinedAt.ToString("dd/MM/yyyy")</span></td>
                            <td>
                                <span class="status-badge @(row.KycStatus == "Approved" ? "badge-success" : row.KycStatus == "Pending" ? "badge-warning" : "badge-secondary")">
                                    <span class="status-dot"></span>
                                    @row.KycStatus
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (!Model.SalesRows.Any() && !Model.RevenueRows.Any() && !Model.ProductRows.Any() && !Model.InventoryRows.Any() && !Model.CustomerRows.Any())
        {
            <div class="empty-row py-5">
                <i class="fa-solid fa-chart-bar fa-2x mb-2"></i>
                <p>No data available for this date range</p>
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════
     EXPORT PROGRESS OVERLAY
══════════════════════════════════════════════ -->
<div class="export-overlay" id="exportOverlay" style="display:none">
    <div class="export-modal">
        <div class="export-icon">
            <i class="fa-solid fa-file-export fa-spin"></i>
        </div>
        <h4>Preparing your report...</h4>
        <div class="export-progress">
            <div class="export-progress-fill" id="exportFill"></div>
        </div>
        <p class="export-sub" id="exportMsg">Gathering data...</p>
    </div>
</div>

@section Scripts {
    <script>
        // ── Data injected by Razor ────────────────────────────────────
        const MONTH_LABELS  = @Html.Raw(monthLabels);
        const MONTH_REVENUE = @Html.Raw(monthRevenue);
        const MONTH_ORDERS  = @Html.Raw(monthOrders);

        // getChartColors() and registerChart() come from admin.js (top-level globals)

        Chart.defaults.font.family = "'Outfit', sans-serif";

        // ── HEADER DUAL-AXIS CHART ────────────────────────────────────
        let reportChart;
        function buildReportChart() {
            const c = getChartColors();
            Chart.defaults.color = c.text;
            if (reportChart) reportChart.destroy();

            const ctx = document.getElementById('reportChart')?.getContext('2d');
            if (!ctx) return;

            const grad = ctx.createLinearGradient(0, 0, 0, 280);
            grad.addColorStop(0, c.goldGrad0);
            grad.addColorStop(1, c.goldGrad1);

            reportChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: MONTH_LABELS,
                    datasets: [
                        {
                            label: 'Revenue (EGP)',
                            data:  MONTH_REVENUE,
                            borderColor: c.gold, borderWidth: 3,
                            backgroundColor: grad, fill: true, tension: 0.4,
                            pointRadius: 4, pointBackgroundColor: c.gold,
                            pointHoverRadius: 7,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Orders',
                            data:  MONTH_ORDERS,
                            borderColor: c.blue, borderWidth: 2,
                            backgroundColor: 'transparent',
                            fill: false, tension: 0.4,
                            pointRadius: 3, pointBackgroundColor: c.blue,
                            borderDash: [6, 3],
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    interaction: { intersect: false, mode: 'index' },
                    animation: { duration: 1200, easing: 'easeInOutQuart' },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: { color: c.text, usePointStyle: true, pointStyleWidth: 10 }
                        },
                        tooltip: {
                            backgroundColor: c.tooltip,
                            borderColor: c.gold, borderWidth: 1,
                            padding: 12,
                            titleColor: c.tooltipText,
                            bodyColor:  c.tooltipText
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: c.grid },
                            ticks: { color: c.text }
                        },
                        y: {
                            grid: { color: c.grid },
                            ticks: { color: c.text, callback: v => v.toLocaleString() + ' EGP' },
                            position: 'left'
                        },
                        y1: {
                            grid: { display: false },
                            ticks: { color: c.blue },
                            position: 'right'
                        }
                    }
                }
            });
        }
        buildReportChart();
        registerChart('reportChart', buildReportChart);

        // ── Table live search ─────────────────────────────────────────
        document.getElementById('tableSearch')?.addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#dataTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });

               
        // ── Export — reads current filter state from the page ───────────
        function getCurrentParams() {
            // Read the active report type from the active tab
            const activeTab = document.querySelector('.report-tab.active');
            const reportType = activeTab?.dataset.reportType
                ?? new URLSearchParams(window.location.search).get('reportType')
                ?? 'revenue';
 
            const params = new URLSearchParams(window.location.search);
            const from = params.get('from') ?? '';
            const to   = params.get('to')   ?? '';
 
            return { reportType, from, to };
        }

         function runExportAnimation(callback) {
            const overlay = document.getElementById('exportOverlay');
            const fill    = document.getElementById('exportFill');
            const msg     = document.getElementById('exportMsg');
 
            overlay.style.display = 'flex';
            fill.style.width      = '0%';
 
            const steps = [
                { pct: 20,  ms: 300,  msg: 'Gathering data...' },
                { pct: 50,  ms: 600,  msg: 'Processing report...' },
                { pct: 80,  ms: 900,  msg: 'Formatting file...' },
                { pct: 100, ms: 1200, msg: 'Download starting...' }
            ];
 
            steps.forEach(({ pct, ms, msg: m }) => {
                setTimeout(() => {
                    fill.style.width = pct + '%';
                    msg.textContent  = m;
                }, ms);
            });
 
            // Trigger the actual download after animation starts
            setTimeout(() => {
                callback();
                // Close modal after a short delay so user sees "Download starting"
                setTimeout(() => { overlay.style.display = 'none'; }, 1000);
            }, 600);
        }

        // Attach to the export buttons
         function exportPDF() {
            const { reportType, from, to } = getCurrentParams();
            runExportAnimation(() => {
                // Open print page in new tab — browser print dialog appears
                const url = `/Export/Pdf?reportType=${reportType}&from=${from}&to=${to}`;
                window.open(url, '_blank');
            });
        }
 
        document.getElementById('exportOverlay')?.addEventListener('click', function (e) {
            if (e.target === this) this.style.display = 'none';
        });
        
        function exportExcel() {
            const { reportType, from, to } = getCurrentParams();
            runExportAnimation(() => {
                // Navigate to the export endpoint — browser handles the download
                const url = `/Export/Excel?reportType=${reportType}&from=${from}&to=${to}`;
                window.location.href = url;
            });
        }

        document.getElementById('exportOverlay')?.addEventListener('click', function (e) {
            if (e.target === this) this.style.display = 'none';
        });
    </script>
}

