@model Tibr.MVC.Models.Products.InventoryViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Inventory Management";
    ViewData["PageTitle"] = "Inventory";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Inventory Management</h1>
        <p class="page-sub">Monitor and update stock levels across all precious metal products</p>
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn-tibr btn-tibr-outline">
        <i class="fa-solid fa-arrow-left"></i>
        Back to Products
    </a>
</div>

<!-- ══════════════════════════════════════════════
     INVENTORY STAT CARDS
══════════════════════════════════════════════ -->
<div class="prod-stats-strip reveal">
    <div class="pstat-card">
        <div class="pstat-icon"><i class="fa-solid fa-cubes"></i></div>
        <div>
            <span class="pstat-label">Total Stock Units</span>
            <strong class="pstat-val">@Model.TotalStockUnits.ToString("N0")</strong>
        </div>
    </div>
    <div class="pstat-card">
        <div class="pstat-icon gold"><i class="fa-solid fa-coins"></i></div>
        <div>
            <span class="pstat-label">Total Stock Value</span>
            <strong class="pstat-val">@Model.TotalStockValue.ToString("N0") EGP</strong>
        </div>
    </div>
    <div class="pstat-card">
        <div class="pstat-icon yellow"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div>
            <span class="pstat-label">Low Stock (≤5)</span>
            <strong class="pstat-val">@Model.LowStockCount products</strong>
        </div>
    </div>
    <div class="pstat-card">
        <div class="pstat-icon red"><i class="fa-solid fa-circle-xmark"></i></div>
        <div>
            <span class="pstat-label">Out of Stock</span>
            <strong class="pstat-val">@Model.OutOfStockCount products</strong>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     FILTER BAR
══════════════════════════════════════════════ -->
<div class="filter-card reveal">
    <form asp-action="Inventory" method="get" class="filter-form-row">
        <div class="filter-search-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" value="@Model.SearchKeyword"
                   placeholder="Search product name..."
                   class="filter-input filter-search" />
        </div>

        <div class="metal-chips">
            <span class="chip-label">Metal:</span>
            <a asp-action="Inventory" asp-route-search="@Model.SearchKeyword"
               asp-route-stockLevel="@Model.StockFilter"
               class="chip @(string.IsNullOrEmpty(Model.MetalTypeFilter) ? "chip-active" : "")">All</a>
            <a asp-action="Inventory" asp-route-search="@Model.SearchKeyword"
               asp-route-metalType="Gold" asp-route-stockLevel="@Model.StockFilter"
               class="chip chip-gold @(Model.MetalTypeFilter == "Gold" ? "chip-active" : "")">
                <i class="fa-solid fa-coins"></i> Gold
            </a>
            <a asp-action="Inventory" asp-route-search="@Model.SearchKeyword"
               asp-route-metalType="Silver" asp-route-stockLevel="@Model.StockFilter"
               class="chip chip-silver @(Model.MetalTypeFilter == "Silver" ? "chip-active" : "")">
                <i class="fa-solid fa-circle-dot"></i> Silver
            </a>
        </div>

        <select name="stockFilter" class="filter-input filter-select">
            <option value="">All Stock Levels</option>
            <option value="ok" selected="@(Model.StockFilter == "ok")">In Stock</option>
            <option value="low" selected="@(Model.StockFilter == "low")">Low Stock (≤5)</option>
            <option value="out" selected="@(Model.StockFilter == "out")">Out of Stock</option>
        </select>

        <button type="submit" class="btn-tibr btn-tibr-gold btn-sm">
            <i class="fa-solid fa-filter"></i> Filter
        </button>
        <a asp-action="Inventory" class="btn-tibr btn-tibr-outline btn-sm">
            <i class="fa-solid fa-rotate-left"></i>
        </a>
    </form>
</div>

<!-- ══════════════════════════════════════════════
     INVENTORY TABLE
══════════════════════════════════════════════ -->
<div class="table-card reveal">
    <div class="table-card-header">
        <h3 class="chart-title">
            Stock Levels
            <span class="table-count-badge">@Model.TotalCount products</span>
        </h3>
        <span class="inv-last-updated">
            <i class="fa-solid fa-clock"></i>
            Last updated: @DateTime.Now.ToString("HH:mm, dd MMM yyyy")
        </span>
    </div>

    <div class="table-responsive">
        <table class="tibr-table">
            <thead>
                <tr>
                    <th style="width:60px">Image</th>
                    <th>Product</th>
                    <th>Metal</th>
                    <th>Weight</th>
                    <th>Buy Price</th>
                    <th>Sell Price</th>
                    <th>Stock Value</th>
                    <th>Current Stock</th>
                    <th>Status</th>
                    <th style="width:220px">Update Stock</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Products.Any())
                {
                    <tr>
                        <td colspan="10" class="empty-row">
                            <i class="fa-solid fa-box-open"></i>
                            No products found
                        </td>
                    </tr>
                }
                @foreach (var p in Model.Products)
                {
                    <tr class="table-row-anim @(p.Stock == 0 ? "row-critical" : p.Stock <= 5 ? "row-warning" : "")">
                        <td>
                            <div class="prod-thumb">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name" />
                                }
                                else
                                {
                                    <div class="prod-thumb-placeholder">
                                        <i class="fa-solid fa-coins"></i>
                                    </div>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="prod-name-cell">
                                <span class="prod-name">@p.Name</span>
                                <span class="prod-created">@p.Weight g · @p.MetalType</span>
                            </div>
                        </td>
                        <td>
                            <span class="metal-badge @(p.MetalType == "Gold" ? "metal-gold" : "metal-silver")">
                                @p.MetalType
                            </span>
                        </td>
                        <td class="text-muted-sm">@p.Weight g</td>
                        <td class="text-muted-sm">@p.BuyPrice.ToString("N2") EGP</td>
                        <td><strong class="price-cell">@p.SellPrice.ToString("N2") EGP</strong></td>
                        <td class="text-muted-sm">@p.StockValue.ToString("N0") EGP</td>
                        <td>
                            <div class="stock-display">
                                <span class="stock-number @p.StockStatusClass">@p.Stock</span>
                                <span class="stock-label-sm">@p.StockStatusLabel</span>
                                <!-- Visual stock bar -->
                                <div class="inv-stock-bar">
                                    <div class="inv-stock-fill @p.StockStatusClass"
                                         style="width:@Math.Min(100,(int)(p.Stock / 100.0 * 100))%">
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge @(p.Status == "Active" ? "badge-success" : "badge-secondary")">
                                <span class="status-dot"></span>
                                @p.Status
                            </span>
                        </td>
                        <td>
                            <!-- Inline quick-update form -->
                            <form asp-controller="Product" asp-action="UpdateStock"
                                  method="post" class="stock-update-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@p.Id" />
                                <div class="stock-update-row">
                                    <input type="number" name="NewStock"
                                           value="@p.Stock" min="0"
                                           class="filter-input stock-input"
                                           placeholder="New qty" />
                                    <button type="submit" class="btn-tibr btn-tibr-gold btn-sm">
                                        <i class="fa-solid fa-floppy-disk"></i>
                                        Save
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="tibr-pagination">
            <span class="pag-info">
                Showing @((Model.PageNumber - 1) * Model.PageSize + 1)–@Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)
                of @Model.TotalCount
            </span>
            <div class="pag-controls">
                @if (Model.HasPrevious)
                {
                    <a asp-action="Inventory"
                       asp-route-pageNumber="@(Model.PageNumber - 1)"
                       asp-route-search="@Model.SearchKeyword"
                       asp-route-stockLevel="@Model.StockFilter"
                       asp-route-metalType="@Model.MetalTypeFilter"
                       class="pag-btn"><i class="fa-solid fa-chevron-left"></i></a>
                }
                @for (int i = Math.Max(1, Model.PageNumber - 2);
                         i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                {
                    <a asp-action="Inventory"
                       asp-route-pageNumber="@i"
                       asp-route-search="@Model.SearchKeyword"
                       asp-route-stockLevel="@Model.StockFilter"
                       asp-route-metalType="@Model.MetalTypeFilter"
                       class="pag-btn @(i == Model.PageNumber ? "pag-active" : "")">@i</a>
                }
                @if (Model.HasNext)
                {
                    <a asp-action="Inventory"
                       asp-route-pageNumber="@(Model.PageNumber + 1)"
                       asp-route-search="@Model.SearchKeyword"
                       asp-route-stockLevel="@Model.StockFilter"
                       asp-route-metalType="@Model.MetalTypeFilter"
                       class="pag-btn"><i class="fa-solid fa-chevron-right"></i></a>
                }
            </div>
        </div>
    }
</div>
