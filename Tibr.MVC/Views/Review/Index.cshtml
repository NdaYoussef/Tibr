@model Tibr.MVC.Models.Reviews.ReviewListViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Reviews";
}

<div class="page-header reveal">
    <div>
        <h1 class="page-title">Customer Reviews</h1>
        <p class="page-sub">Monitor and manage customer feedback on orders.</p>
    </div>
</div>

<div class="row mb-4 reveal">
    <div class="col-md-3">
        <div class="pstat-card">
            <div class="pstat-icon"><i class="fa-solid fa-comments"></i></div>
            <div class="pstat-label">Total Reviews</div>
            <div class="pstat-val">@Model.TotalReviews</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pstat-card">
            <div class="pstat-icon" style="color: var(--gold)"><i class="fa-solid fa-star"></i></div>
            <div class="pstat-label">Average Rating</div>
            <div class="pstat-val">@Model.AverageRating ★</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pstat-card">
            <div class="pstat-icon" style="color: var(--green)"><i class="fa-solid fa-certificate"></i></div>
            <div class="pstat-label">5-Star Reviews</div>
            <div class="pstat-val">@Model.FiveStarCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="pstat-card">
            <div class="pstat-icon" style="color: var(--red)"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="pstat-label">Low Rating (1-2★)</div>
            <div class="pstat-val">@Model.LowRatingCount</div>
        </div>
    </div>
</div>

<div class="filter-card mb-4 reveal">
    <form asp-action="Index" method="get" class="filter-form-row">
        <div class="filter-search-wrap">
            <i class="fa-solid fa-magnifying-glass filter-search"></i>
            <input type="text" name="search" value="@Model.SearchKeyword" class="filter-input" placeholder="Search by customer or order...">
        </div>
        
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted small">Rating:</span>
            <div class="btn-group">
                <a asp-action="Index" asp-route-rating="" asp-route-search="@Model.SearchKeyword" 
                   class="chip @(Model.RatingFilter == null ? "chip-active chip-gold" : "")">All</a>
                @for (int i = 5; i >= 1; i--)
                {
                    <a asp-action="Index" asp-route-rating="@i" asp-route-search="@Model.SearchKeyword" 
                       class="chip @(Model.RatingFilter == i ? "chip-active chip-gold" : "")">@i ★</a>
                }
            </div>
        </div>

        <div class="ms-auto d-flex gap-2">
            <button type="submit" class="btn-tibr btn-tibr-gold">Apply</button>
            <a asp-action="Index" class="btn-tibr btn-tibr-outline"><i class="fa-solid fa-rotate-left me-1"></i>Reset</a>
        </div>
    </form>
</div>

<div class="card reveal" style="background: var(--bg-card); border: none;">
    <div class="card-body p-0">
        @if (!Model.Reviews.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-comment-slash fa-3x text-muted mb-3"></i>
                <h5 class="text-dark">No reviews found</h5>
                <p class="text-muted">Try adjusting your filters or search terms.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Order</th>
                            <th>Rating</th>
                            <th style="width: 40%">Review Text</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var review in Model.Reviews)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@review.UserFullName</div>
                                    <div class="text-muted small">@review.UserEmail</div>
                                </td>
                                <td>
                                    <a href="/Orders/Details/@review.OrderId" class="text-gold fw-bold">#@review.OrderNumber</a>
                                </td>
                                <td>
                                    <span class="@review.RatingClass fw-bold" style="letter-spacing: 1px;">
                                        @review.StarDisplay
                                    </span>
                                </td>
                                <td>
                                    <div class="text-muted small">
                                        @if (string.IsNullOrEmpty(review.Description))
                                        {
                                            <em>No comment provided.</em>
                                        }
                                        else
                                        {
                                            @(review.Description.Length > 80 ? review.Description.Substring(0, 80) + "..." : review.Description)
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="text-dark small">@review.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <div class="text-muted x-small">@review.TimeAgo</div>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Details" asp-route-id="@review.Id" class="btn-tibr btn-tibr-outline btn-sm">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@review.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                            <button type="submit" class="btn-tibr btn-tibr-danger btn-sm">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalItems > Model.PageSize)
            {
                <div class="d-flex justify-content-between align-items-center p-3 border-top border-dark">
                    <div class="text-muted small">
                        Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) to @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems)) of @Model.TotalItems reviews
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchKeyword" asp-route-rating="@Model.RatingFilter">Previous</a>
                            </li>
                            @for (int i = 1; i <= Math.Ceiling((double)Model.TotalItems / Model.PageSize); i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchKeyword" asp-route-rating="@Model.RatingFilter">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Math.Ceiling((double)Model.TotalItems / Model.PageSize) ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchKeyword" asp-route-rating="@Model.RatingFilter">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<style>
    .rating-high { color: var(--gold); }
    .rating-mid { color: var(--yellow); }
    .rating-low { color: var(--red); opacity: 0.8; }
    .text-gold { color: var(--gold); text-decoration: none; }
    .text-gold:hover { color: var(--gold-light); }
    .x-small { font-size: 0.75rem; }
    .pagination .page-link { background: var(--bg-card-2); border-color: #2e354f; color: var(--text-muted); }
    .pagination .page-item.active .page-link { background: var(--gold); border-color: var(--gold); color: white; }
</style>